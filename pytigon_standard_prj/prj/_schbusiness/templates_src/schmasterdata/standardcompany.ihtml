% extends "forms/form.html"

% load exfiltry
% load exsyntax

%% all
    % with table_type='datatable':
        {{ block.super }}

%% scroll

%% list_row_header
    th..._(Name)
    th..._(Description)
    

%% list_row
    td...{{ object.name }}
    td...{{ object.description }}
    
%% list_row_actions
    % row_actions:
        .edit
        .delete

%% list_content_actions
    % new_row "New customer"

%% row_edit
    % form: 
        .parent:!,type:!,code,name,description
