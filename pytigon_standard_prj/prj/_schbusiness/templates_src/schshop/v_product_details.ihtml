% extends "forms/user_tab.html"

% load exfiltry
% load exsyntax


%% all
    %with show_title_bar=1 title='<<form_title>>'
        {{ block.super }}


%% user_header
    th...X1
    th...Y1


%% user_row
    tr
        td... {{object.0}}
        td align=right... {{object.1}}
        td align=right... {{object.2|to_int}}

