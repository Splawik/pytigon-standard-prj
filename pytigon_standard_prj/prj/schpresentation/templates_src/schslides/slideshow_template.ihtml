html
    head
        meta charser=utf-8 
        script src=/jquery-3.2.1.min.js
        script src=/slideshow.js
        link rel=stylesheet,,,href=/slideshow.css
    body
        {% for widget in widgets %}{{ widget| safe }}
        {% endfor %}
    <script>
    .SLIDES = [
    {% for step in steps %}    [ '{{step.0}}', '{{step.1}}' ], 
    {% endfor %}]
    .jQuery( document ).ready(function() { return run(SLIDES); })
    </script>
    